# ============================================================
# SentinelClaw — Umgebungsvariablen
# ============================================================
# Kopiere diese Datei als .env und fülle die Werte aus:
#   cp .env.example .env
#
# ACHTUNG: .env wird NICHT committed (siehe .gitignore)
# ============================================================

# --- LLM Provider (PFLICHT) ---
# Optionen:
#   "claude-abo" = Claude Code CLI (nutzt dein Abo, KEIN API-Key nötig)
#   "claude"     = Anthropic API (braucht SENTINEL_CLAUDE_API_KEY)
#   "azure"      = Azure OpenAI (braucht Azure-Credentials)
#   "ollama"     = Lokales LLM (kein Datenabfluss)
SENTINEL_LLM_PROVIDER=claude-abo

# --- Ollama (nur wenn SENTINEL_LLM_PROVIDER=ollama) ---
# Höchste Datenschutzstufe: Alles bleibt lokal, kein AVV nötig
SENTINEL_OLLAMA_BASE_URL=http://localhost:11434
SENTINEL_OLLAMA_MODEL=llama3.1:70b

# --- Azure OpenAI (nur wenn SENTINEL_LLM_PROVIDER=azure) ---
# Hohe Datenschutzstufe: EU-Rechenzentren, AVV über Azure EA
SENTINEL_AZURE_ENDPOINT=https://DEINE-FIRMA.openai.azure.com
SENTINEL_AZURE_API_KEY=DEIN_AZURE_KEY_HIER
SENTINEL_AZURE_DEPLOYMENT=gpt-4o
SENTINEL_AZURE_API_VERSION=2024-08-01-preview

# --- Claude / Anthropic (nur wenn SENTINEL_LLM_PROVIDER=claude) ---
# ⚠ Daten werden an Anthropic (USA) übertragen
# ⚠ Für DSGVO-konformen Enterprise-Einsatz: AVV mit Anthropic nötig
SENTINEL_CLAUDE_API_KEY=sk-ant-DEIN_KEY_HIER
SENTINEL_CLAUDE_MODEL=claude-sonnet-4-20250514

# --- LLM Token-Budget ---
SENTINEL_LLM_MAX_TOKENS_PER_SCAN=50000
SENTINEL_LLM_MONTHLY_TOKEN_LIMIT=1000000
SENTINEL_LLM_TIMEOUT=120

# --- Scan-Konfiguration ---
SENTINEL_ALLOWED_TARGETS=10.10.10.0/24
SENTINEL_SANDBOX_TIMEOUT=300
SENTINEL_MAX_CONCURRENT_SCANS=1

# --- Logging ---
SENTINEL_LOG_LEVEL=INFO

# --- MCP-Server ---
SENTINEL_MCP_PORT=8080
SENTINEL_MCP_HOST=0.0.0.0

# --- Docker / Sandbox ---
SENTINEL_SANDBOX_IMAGE=sentinelclaw/sandbox:latest
SENTINEL_SANDBOX_MEMORY_LIMIT=2g
SENTINEL_SANDBOX_CPU_LIMIT=2.0

# --- Datenbank (Produkt — im PoC wird SQLite genutzt) ---
# SENTINEL_DB_HOST=localhost
# SENTINEL_DB_PORT=5432
# SENTINEL_DB_NAME=sentinelclaw
# SENTINEL_DB_USER=sentinel
# SENTINEL_DB_PASSWORD=DEIN_DB_PASSWORT
# SENTINEL_DB_SSL=true

# --- Verschlüsselung ---
# SENTINEL_ENCRYPTION_KEY=DEIN_256_BIT_KEY_BASE64
